[Unit]
Description=OpenTelemetry Collector
After=network.target

[Service]
EnvironmentFile={{ otel_collector_config_folder }}/otelcol.conf
ExecStart={{ otel_collector_install_folder }}/bin/otelcol $OTELCOL_OPTIONS
KillMode=mixed
Restart=on-failure
Type=simple
User={{ otel_collector_service_user }}
Group={{ otel_collector_service_group }}

[Install]
WantedBy=multi-user.target
